<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8fafc;
        }

        .gradient-text {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>

<body class="text-slate-800 antialiased min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="bg-white border-b border-slate-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16">
                <div class="flex items-center">
                    <div class="flex-shrink-0 flex items-center gap-2">
                        <div
                            class="w-8 h-8 rounded-lg bg-emerald-500 flex items-center justify-center text-white font-bold text-xl">
                            W</div>
                        <span class="font-bold text-xl gradient-text">Wattwise Admin</span>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <a href="/status" target="_blank"
                        class="text-sm font-medium text-slate-500 hover:text-emerald-500 transition-colors">Server
                        Status</a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
        <!-- Stats Overview -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 flex flex-col justify-center">
                <h3 class="text-sm font-medium text-slate-500 mb-1">Total Waitlist Entries</h3>
                <div class="text-3xl font-bold text-slate-900">
                    <%= totalCount %>
                </div>
            </div>
            <div
                class="bg-gradient-to-br from-emerald-500 to-teal-600 rounded-2xl shadow-sm border border-emerald-400 p-6 flex flex-col justify-center text-white">
                <h3 class="text-sm font-medium text-emerald-100 mb-1">Status</h3>
                <div class="text-xl font-semibold flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-emerald-300 animate-pulse"></span>
                    API Active & Monitoring
                </div>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div class="px-6 py-5 border-b border-slate-200 flex items-center justify-between">
                <h3 class="text-lg font-semibold text-slate-900">Recent Signups</h3>
                <span
                    class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-800">
                    Latest <%= users.length %>
                </span>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th scope="col"
                                class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                                Email Address</th>
                            <th scope="col"
                                class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                                Joined Date</th>
                            <th scope="col"
                                class="px-6 py-3 text-left text-xs font-semibold text-slate-500 uppercase tracking-wider">
                                Client Context</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-100">
                        <% if (users && users.length> 0) { %>
                            <% users.forEach(function(user) { %>
                                <tr class="hover:bg-slate-50 transition-colors duration-150">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-slate-900">
                                        <%= user.email %>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-slate-500">
                                        <%= new Date(user.joinedAt).toLocaleString() %>
                                    </td>
                                    <td class="px-6 py-4 text-sm text-slate-500 max-w-xs truncate"
                                        title="<%= user.userAgent || 'Unknown' %>">
                                        <div class="flex flex-col">
                                            <span>
                                                <%= user.ipAddress || 'Unknown IP' %>
                                            </span>
                                            <span class="text-xs text-slate-400">
                                                <%= user.userAgent ? user.userAgent.substring(0, 30) + '...'
                                                    : 'Unknown Client' %>
                                            </span>
                                        </div>
                                    </td>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="3" class="px-6 py-10 text-center text-sm text-slate-500">
                                                No waitlist entries found yet.
                                            </td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>

            <div class="px-6 py-4 bg-slate-50 border-t border-slate-200 flex items-center justify-between">
                <div class="text-sm text-slate-500">
                    Showing <% if (totalCount===0) { %>0<% } else { %>
                            <%= ((currentPage - 1) * 50) + 1 %> to <%= Math.min(totalCount, currentPage * 50) %>
                                    <% } %> of <%= totalCount %> results
                </div>
                <!-- Simple pagination links -->
                <div class="flex gap-2 text-sm font-medium">
                    <% if(currentPage> 1) { %>
                        <a href="/admin?page=<%= currentPage - 1 %>"
                            class="text-emerald-600 hover:text-emerald-500 border border-emerald-200 bg-white px-3 py-1 rounded">Previous</a>
                        <% } %>
                            <% if(hasMore) { %>
                                <a href="/admin?page=<%= currentPage + 1 %>"
                                    class="text-emerald-600 hover:text-emerald-500 border border-emerald-200 bg-white px-3 py-1 rounded">Next</a>
                                <% } %>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="mt-auto py-6 bg-white border-t border-slate-200 text-center">
        <p class="text-sm text-slate-500">&copy; <%= new Date().getFullYear() %> Wattwise Admin. All rights reserved.
        </p>
    </footer>
</body>

</html>